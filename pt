<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Elite Fitness Coaching</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #111;
      color: white;
    }

    header {
      background: #000;
      padding: 20px;
      text-align: center;
      font-size: 28px;
      font-weight: bold;
      letter-spacing: 2px;
    }

    nav {
      display: flex;
      justify-content: center;
      background: #1a1a1a;
      padding: 10px;
    }

    nav a {
      color: white;
      margin: 0 15px;
      text-decoration: none;
      font-weight: bold;
    }

    .hero {
      background: url('https://images.unsplash.com/photo-1554284126-aa88f22d8b74') no-repeat center/cover;
      height: 80vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
    }

    .hero h1 {
      font-size: 48px;
      background: rgba(0,0,0,0.6);
      padding: 20px;
      border-radius: 10px;
    }

    .section {
      padding: 50px 20px;
      text-align: center;
    }

    .services {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
    }

    .card {
      background: #1a1a1a;
      margin: 15px;
      padding: 20px;
      width: 250px;
      border-radius: 10px;
    }

    .card h3 {
      color: #00ffcc;
    }

    .btn {
      display: inline-block;
      padding: 12px 25px;
      background: #00ffcc;
      color: black;
      text-decoration: none;
      border-radius: 5px;
      margin-top: 10px;
      font-weight: bold;
    }

    footer {
      background: #000;
      text-align: center;
      padding: 20px;
      margin-top: 30px;
    }

    @media (max-width: 768px) {
      .hero h1 {
        font-size: 32px;
      }
      .services {
        flex-direction: column;
        align-items: center;
      }
    }
  </style>
</head>

<body>

<header>ELITE FITNESS COACHING</header>

<nav>
  <a href="#">Home</a>
  <a href="#services">Services</a>
  <a href="#about">About</a>
  <a href="#contact">Contact</a>
</nav>

<div class="hero">
  <h1>Transform Your Body & Mind</h1>
</div>

<div class="section" id="services">
  <h2>My Services</h2>
  <div class="services">
    <div class="card">
      <h3>1-on-1 Coaching</h3>
      <p>Personalised training plans tailored to your goals.</p>
    </div>
    <div class="card">
      <h3>Online Coaching</h3>
      <p>Train from anywhere with custom workout programs.</p>
    </div>
    <div class="card">
      <h3>Nutrition Plans</h3>
      <p>Simple, effective meal plans to fuel your progress.</p>
    </div>
  </div>
</div>

<div class="section" id="about">
  <h2>About Me</h2>
  <p>I’m a certified personal trainer helping clients build strength, lose fat, and gain confidence.</p>
</div>

<div class="section" id="contact">
  <h2>Contact Me</h2>
  <p>Email: yourname@email.com</p>
  <p>Instagram: @yourfitness</p>
  <a href="#" class="btn">Start Your Journey</a>
</div>

<footer>
  © 2026 Elite Fitness Coaching | All Rights Reserved
</footer>

</body>
</html>
